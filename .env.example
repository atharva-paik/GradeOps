# Application
APP_NAME=GRADEOPS
DEBUG=false
API_PREFIX=/api/v1

# Database (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://gradeops:gradeops@localhost:5432/gradeops

# Storage paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MODELS_CACHE_DIR=models_cache

# Storage backend: local | s3
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=gradeops

# OCR settings
# Options: florence2 | nougat | tesseract | easyocr | paddleocr
OCR_ENGINE=tesseract
OCR_DEVICE=cpu
OCR_PREPROCESS=true
FLORENCE_MODEL_ID=microsoft/Florence-2-base
NOUGAT_MODEL_ID=facebook/nougat-base

# Evaluation
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.55
BLANK_ANSWER_MIN_CHARS=3
PLAGIARISM_SIMILARITY_THRESHOLD=0.92

# Optional AI (heuristic grading works offline without these)
AI_BACKEND=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.2-3B-Instruct
USE_LLM_REASONING=false

# Auth (false = open API, backward compatible with MVP)
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Batch processing
BATCH_MAX_WORKERS=2

# PDF processing
PDF_DPI=200
MAX_UPLOAD_MB=50

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
